FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=change-me-in-production-use-a-long-random-string

# Токен бота, выданный @BotFather. Нужен и здесь (для вызовов Telegram
# API), и на основном сайте (для проверки подписи Telegram Login Widget —
# см. ARCHITECTURE.md) — это требование протокола Login Widget, не наша
# прихоть: подпись проверяется секретом SHA256(bot_token).
TELEGRAM_BOT_TOKEN=

# Секрет вебхука Telegram -> бот. Придумайте длинную случайную строку,
# передайте её в setWebhook(secret_token=...) — Telegram будет присылать
# её обратно в заголовке X-Telegram-Bot-Api-Secret-Token на каждый вызов.
TELEGRAM_WEBHOOK_SECRET=

# Случайный длинный сегмент пути вебхука (доп. слой к секрету выше) —
# итоговый URL: https://<домен>/telegram/webhook/<это значение>
TELEGRAM_WEBHOOK_PATH_TOKEN=

# Базовый URL API основного сайта (MS), например:
# https://mafiastyle.pythonanywhere.com
MAIN_API_BASE_URL=

# Серверный токен для авторизации запросов бота к /api/v1/bot/* на
# основном сайте (Authorization: Bearer <это значение>). Секрет,
# известный только двум серверам — никогда не виден пользователю.
MAIN_API_SERVICE_TOKEN=

# Общий HMAC-секрет для входящих уведомлений ОТ основного сайта
# (POST /events/<type>, заголовок X-Signature = HMAC-SHA256(тело, секрет)).
INCOMING_EVENT_SECRET=
